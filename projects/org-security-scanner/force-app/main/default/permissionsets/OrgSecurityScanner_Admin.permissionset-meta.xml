<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Grants access to all Org Security Scanner objects, tabs, and the export file feature. Assign to security administrators only.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>OrgSecurityScanner Admin</label>
    <license>Salesforce</license>

    <!-- Object permissions: SecurityScanRun__c -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <object>SecurityScanRun__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Object permissions: SecurityFinding__c -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <object>SecurityFinding__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Object permissions: ContentVersion (required for exportFindingsCsv) -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>ContentVersion</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Object permissions: ContentDocumentLink (required for exportFindingsCsv) -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>ContentDocumentLink</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Tab visibility -->
    <tabSettings>
        <tab>OrgSecurityScanner</tab>
        <visibility>Visible</visibility>
    </tabSettings>

