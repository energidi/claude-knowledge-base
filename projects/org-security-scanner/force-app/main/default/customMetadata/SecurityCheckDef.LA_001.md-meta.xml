    <label>LA-001 - LWC component uses lwc:dom=manual</label>
    <protected>false</protected>
    <values>
        <field>CheckId__c</field>
        <value xsi:type="xsd:string">LA-001</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">LWC component uses lwc:dom=manual</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">LWC &amp; Aura</value>
    </values>
    <values>
        <field>CategoryCode__c</field>
        <value xsi:type="xsd:string">LA</value>
    </values>
    <values>
        <field>Severity__c</field>
