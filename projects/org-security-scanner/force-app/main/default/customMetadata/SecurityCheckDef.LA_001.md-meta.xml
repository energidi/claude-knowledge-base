    </values>
    <values>
        <field>FindingType__c</field>
        <value xsi:type="xsd:string">Recommendation</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">One or more LWC component bundles contain the lwc:dom=manual directive in their templates. This enables direct DOM manipulation via innerHTML, bypassing LWC automatic XSS protection. This is a heuristic check - manual code review required to confirm.</value>
    </values>
    <values>
        <field>Impact__c</field>
        <value xsi:type="xsd:string">lwc:dom=manual enables direct innerHTML assignment. Any user-supplied data rendered this way is a stored or reflected XSS vector that can steal session tokens or perform actions on behalf of the user.</value>
    </values>
    <values>
        <field>Remediation__c</field>
        <value xsi:type="xsd:string">Remove lwc:dom=manual and replace with LWC data-binding ({expression}) which auto-escapes output. If dynamic HTML is genuinely required, sanitize with DOMParser and inject only known-safe node types.</value>
    </values>
    <values>
        <field>SalesforceDocUrl__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>