        <value xsi:type="xsd:string">Guest user object permissions allow Create=true on Case or Lead. Anonymous visitors can submit cases or leads without authentication.</value>
    </values>
    <values>
        <field>Impact__c</field>
        <value xsi:type="xsd:string">Junk Case and Lead records from anonymous visitors pollute sales and support pipelines, waste agent time, and may trigger paid integrations or SLA timers.</value>
    </values>
