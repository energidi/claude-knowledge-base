    <label>SA-003 - Session timeout exceeds 8 hours</label>
    <protected>false</protected>
    <values>
        <field>CheckId__c</field>
        <value xsi:type="xsd:string">SA-003</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Session timeout exceeds 8 hours</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Session &amp; Auth</value>
    </values>
    <values>
        <field>CategoryCode__c</field>
        <value xsi:type="xsd:string">SA</value>
    </values>
    <values>
        <field>Severity__c</field>
