    </values>
    <values>
        <field>FindingType__c</field>
        <value xsi:type="xsd:string">Automated</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">The session timeout is set to more than 8 hours of inactivity. Sessions remain valid for an extended period after the user stops interacting with the org.</value>
    </values>
    <values>
        <field>Impact__c</field>
        <value xsi:type="xsd:string">Long-lived sessions on shared workstations or public computers increase the window for session hijacking. An unattended browser tab provides an easy attack path.</value>
    </values>
    <values>
        <field>Remediation__c</field>
        <value xsi:type="xsd:string">Set SessionTimeout to 2 hours or less in Setup &gt; Session Settings. For high-privilege admin accounts, consider a shorter timeout of 30-60 minutes.</value>
    </values>
