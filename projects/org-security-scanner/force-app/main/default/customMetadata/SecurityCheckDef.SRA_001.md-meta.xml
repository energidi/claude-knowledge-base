    <label>SRA-001 - Account OWD set to Public Read</label>
    <protected>false</protected>
    <values>
        <field>CheckId__c</field>
        <value xsi:type="xsd:string">SRA-001</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Account OWD set to Public Read/Write</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Sharing &amp; Record Access</value>
    </values>
    <values>
        <field>CategoryCode__c</field>
        <value xsi:type="xsd:string">SRA</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Critical</value>
    </values>
    <values>
        <field>FindingType__c</field>
        <value xsi:type="xsd:string">Automated</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">The org-wide default sharing model for Account is set to Public Read/Write. Every user in the org can edit or delete any Account record without restriction.</value>
    </values>
    <values>
        <field>Impact__c</field>
        <value xsi:type="xsd:string">Every user in the org can edit or delete any Account record without restriction. A single compromised or careless user can corrupt or delete the entire Account dataset.</value>
    </values>
    <values>
        <field>Remediation__c</field>
        <value xsi:type="xsd:string">Change Account OWD to Private or Public Read Only in Setup &gt; Sharing Settings. Use sharing rules to restore legitimate access for teams that need cross-ownership visibility.</value>
    </values>
