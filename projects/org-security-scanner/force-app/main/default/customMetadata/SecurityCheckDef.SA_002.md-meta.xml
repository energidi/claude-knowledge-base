    <label>SA-002 - Password never expires on active profiles</label>
    <protected>false</protected>
    <values>
        <field>CheckId__c</field>
        <value xsi:type="xsd:string">SA-002</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Password never expires on active profiles</value>
