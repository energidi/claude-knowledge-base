    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">One or more active profiles have a password expiration policy set to Never. Passwords for users on these profiles never expire.</value>
    </values>
    <values>
        <field>Impact__c</field>
        <value xsi:type="xsd:string">Compromised credentials remain valid indefinitely. An attacker who obtains a password through a data breach or phishing attack retains access forever unless the account is manually deactivated.</value>
    </values>
    <values>
        <field>Remediation__c</field>
        <value xsi:type="xsd:string">Set PasswordExpiration to 90 days or less on all active profiles in Setup &gt; Password Policies.</value>
    </values>
