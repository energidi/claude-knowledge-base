<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <label>MS-002 - Custom Settings with credential</label>
    <protected>false</protected>
    <values>
        <field>CheckId__c</field>
        <value xsi:type="xsd:string">MS-002</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Custom Settings with credential-like fields</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Metadata &amp; Secrets</value>
    </values>
    <values>
        <field>CategoryCode__c</field>
        <value xsi:type="xsd:string">MS</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">High</value>
    </values>
    <values>
        <field>FindingType__c</field>
        <value xsi:type="xsd:string">Automated</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">Custom Setting objects (List or Hierarchy type) have fields with API names matching *Token*, *Key*, *Secret*, or *Password* patterns that contain non-empty values.</value>
    </values>
    <values>
        <field>Impact__c</field>
        <value xsi:type="xsd:string">Credentials in Custom Settings are readable via SOQL from any Apex context with access to the setting object. Unlike CMT, Custom Settings do not deploy with packages but are readable by any code.</value>
    </values>
    <values>
        <field>Remediation__c</field>
        <value xsi:type="xsd:string">Migrate credentials from Custom Settings to Named Credentials or Salesforce Shield Platform Encryption for values that must stay in the platform.</value>
    </values>
