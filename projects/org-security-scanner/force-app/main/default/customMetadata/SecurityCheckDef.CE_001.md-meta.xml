<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <label>CE-001 - Expired active certificate</label>
    <protected>false</protected>
    <values>
        <field>CheckId__c</field>
        <value xsi:type="xsd:string">CE-001</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Expired active certificate</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Certificates &amp; Encryption</value>
    </values>
    <values>
        <field>CategoryCode__c</field>
        <value xsi:type="xsd:string">CE</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Critical</value>
    </values>
    <values>
        <field>FindingType__c</field>
        <value xsi:type="xsd:string">Automated</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">One or more Certificate records in this org have an ExpirationDate on or before today. These certificates are expired and any system relying on them is either broken or operating in a degraded security state.</value>
    </values>
    <values>
        <field>Impact__c</field>
        <value xsi:type="xsd:string">An expired certificate causes immediate failures in all callouts, SAML SSO logins, and JWT signing operations that rely on it. If used for inbound authentication, external users cannot log in.</value>
    </values>
    <values>
        <field>Remediation__c</field>
        <value xsi:type="xsd:string">Renew the expired certificate immediately in Setup &gt; Certificate and Key Management. After renewal, update all Connected Apps, Named Credentials, and IdP configurations that reference the old certificate.</value>
    </values>
    <values>
        <field>SalesforceDocUrl__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>