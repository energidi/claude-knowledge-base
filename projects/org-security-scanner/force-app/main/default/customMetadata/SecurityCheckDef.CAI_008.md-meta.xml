    <label>CAI-008 - Large Connected App inventory</label>
    <protected>false</protected>
    <values>
        <field>CheckId__c</field>
        <value xsi:type="xsd:string">CAI-008</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Large Connected App inventory</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Connected Apps &amp; Integrations</value>
    </values>
    <values>
        <field>CategoryCode__c</field>
        <value xsi:type="xsd:string">CAI</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Low</value>
    </values>
    <values>
        <field>FindingType__c</field>
        <value xsi:type="xsd:string">Automated</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">This org has more than 25 installed Connected Apps. Each Connected App represents a potential OAuth attack surface and an additional integration to monitor and maintain.</value>
    </values>
    <values>
        <field>Impact__c</field>
        <value xsi:type="xsd:string">A large number of Connected Apps increases the probability that at least one is misconfigured, abandoned, or using overly broad OAuth scopes. Unmanaged apps accumulate security debt.</value>
    </values>
    <values>
        <field>Remediation__c</field>
        <value xsi:type="xsd:string">Review all installed Connected Apps in Setup &gt; Connected Apps. Uninstall or disable any apps that are no longer in use. Document the business purpose, owner, and OAuth scope justification for each remaining app.</value>
    </values>
    <values>
        <field>SalesforceDocUrl__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>