    <label>SRA-002 - Contact OWD set to Public Read</label>
    <protected>false</protected>
    <values>
        <field>CheckId__c</field>
        <value xsi:type="xsd:string">SRA-002</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Contact OWD set to Public Read/Write</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Sharing &amp; Record Access</value>
    </values>
    <values>
        <field>CategoryCode__c</field>
