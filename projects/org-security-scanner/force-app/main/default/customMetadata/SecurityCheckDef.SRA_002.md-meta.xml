    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">The org-wide default sharing model for Contact is set to Public Read/Write. Every user can edit or delete any Contact record.</value>
    </values>
    <values>
        <field>Impact__c</field>
        <value xsi:type="xsd:string">Every user can edit or delete any Contact record. This is a common source of accidental mass data corruption and exposes customer PII to all internal users.</value>
    </values>
    <values>
        <field>Remediation__c</field>
        <value xsi:type="xsd:string">Change Contact OWD to Controlled by Parent (recommended) or Private in Setup &gt; Sharing Settings. Controlled by Parent aligns Contact access with the owning Account.</value>
    </values>
