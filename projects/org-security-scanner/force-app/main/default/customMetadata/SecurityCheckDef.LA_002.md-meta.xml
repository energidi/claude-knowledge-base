<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <label>LA-002 - Component accesses document.coo</label>
    <protected>false</protected>
    <values>
        <field>CheckId__c</field>
        <value xsi:type="xsd:string">LA-002</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Component accesses document.cookie or localStorage</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">LWC &amp; Aura</value>
    </values>
    <values>
        <field>CategoryCode__c</field>
        <value xsi:type="xsd:string">LA</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Medium</value>
    </values>
    <values>
        <field>FindingType__c</field>
        <value xsi:type="xsd:string">Recommendation</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">One or more LWC or Aura component bundles access document.cookie or localStorage.setItem in their JavaScript. Sensitive data may be stored outside Salesforce session management. This is a heuristic check - manual code review required to confirm.</value>
    </values>
    <values>
        <field>Impact__c</field>
        <value xsi:type="xsd:string">document.cookie and localStorage accessed in Lightning context can expose session tokens or sensitive data to other scripts on the same domain. This data persists after the user logs out.</value>
    </values>
    <values>
        <field>Remediation__c</field>
        <value xsi:type="xsd:string">Remove direct cookie and localStorage access from Lightning components. Use LWC @wire and @salesforce/apex for data persistence. Session management should be left entirely to the Salesforce platform.</value>
    </values>
    <values>
        <field>SalesforceDocUrl__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>