<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <label>CAI-004 - Outbound Message transmits session ID</label>
    <protected>false</protected>
    <values>
        <field>CheckId__c</field>
        <value xsi:type="xsd:string">CAI-004</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Outbound Message transmits session ID</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Connected Apps &amp; Integrations</value>
    </values>
    <values>
        <field>CategoryCode__c</field>
        <value xsi:type="xsd:string">CAI</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">High</value>
    </values>
    <values>
        <field>FindingType__c</field>
        <value xsi:type="xsd:string">Automated</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">A Workflow Outbound Message has IncludesSessionId=true. The active Salesforce session token is transmitted to the receiving endpoint as part of the message payload.</value>
    </values>
    <values>
        <field>Impact__c</field>
        <value xsi:type="xsd:string">If the receiving endpoint is compromised or the message is intercepted, the session token grants full API access to the org with the permissions of the session owner.</value>
    </values>
    <values>
        <field>Remediation__c</field>
        <value xsi:type="xsd:string">Remove IncludesSessionId from all Outbound Message definitions. Use Named Credentials with OAuth 2.0 for integration authentication instead of session token pass-through.</value>
    </values>
    <values>
        <field>SalesforceDocUrl__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>