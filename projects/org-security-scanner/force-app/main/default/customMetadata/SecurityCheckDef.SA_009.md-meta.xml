<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <label>SA-009 - Password minimum length below 8</label>
    <protected>false</protected>
    <values>
        <field>CheckId__c</field>
        <value xsi:type="xsd:string">SA-009</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Password minimum length below 8 characters</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Session &amp; Auth</value>
    </values>
    <values>
        <field>CategoryCode__c</field>
        <value xsi:type="xsd:string">SA</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Medium</value>
    </values>
    <values>
        <field>FindingType__c</field>
        <value xsi:type="xsd:string">Automated</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">One or more active profile password policies have MinPasswordLength set below 8 characters. Short passwords are trivially cracked by dictionary and brute-force attacks.</value>
    </values>
    <values>
        <field>Impact__c</field>
        <value xsi:type="xsd:string">Short passwords dramatically reduce the keyspace. A 6-character alphanumeric password has approximately 56 billion combinations, crackable in minutes with modern hardware.</value>
    </values>
    <values>
        <field>Remediation__c</field>
        <value xsi:type="xsd:string">Set minimum password length to 8 characters or more on all active profiles in Setup &gt; Password Policies. 12 or more characters is recommended for admin and integration profiles.</value>
    </values>
    <values>
        <field>SalesforceDocUrl__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>