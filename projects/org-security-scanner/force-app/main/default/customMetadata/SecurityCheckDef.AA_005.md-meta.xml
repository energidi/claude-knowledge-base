<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <label>AA-005 - Apex callout to HTTP (non-HTTPS) endpoint</label>
    <protected>false</protected>
    <values>
        <field>CheckId__c</field>
        <value xsi:type="xsd:string">AA-005</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Apex callout to HTTP (non-HTTPS) endpoint</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Apex &amp; Automation</value>
    </values>
    <values>
        <field>CategoryCode__c</field>
        <value xsi:type="xsd:string">AA</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Medium</value>
    </values>
    <values>
        <field>FindingType__c</field>
        <value xsi:type="xsd:string">Recommendation</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">One or more Apex classes call setEndpoint() with a literal http:// URL. HTTP callouts transmit data unencrypted over the network. This is a heuristic check - manual code review required to confirm.</value>
    </values>
    <values>
        <field>Impact__c</field>
        <value xsi:type="xsd:string">HTTP callouts transmit request and response data in plaintext. Any network observer between Salesforce data centers and the target endpoint can read the full payload.</value>
    </values>
    <values>
        <field>Remediation__c</field>
        <value xsi:type="xsd:string">Replace all HTTP endpoint URLs with HTTPS equivalents. Update Remote Site Settings accordingly. Contact the endpoint owner if HTTPS is not yet available - this is a blocker for production use.</value>
    </values>
    <values>
        <field>SalesforceDocUrl__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>