    <label>MON-004 - Event log retention below 30 days</label>
    <protected>false</protected>
    <values>
        <field>CheckId__c</field>
        <value xsi:type="xsd:string">MON-004</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Event log retention below 30 days</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Monitoring</value>
    </values>
    <values>
        <field>CategoryCode__c</field>
        <value xsi:type="xsd:string">MON</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Medium</value>
    </values>
    <values>
        <field>FindingType__c</field>
        <value xsi:type="xsd:string">Automated</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">EventMonitoringSettings has EventLogFileRetentionPeriodInDays set below 30 days. Insufficient log retention prevents effective post-incident investigation.</value>
    </values>
    <values>
        <field>Impact__c</field>
        <value xsi:type="xsd:string">Incident response typically requires 30-90 days of logs to reconstruct attack timelines. With less than 30 days of retention, breaches discovered after the fact cannot be fully investigated.</value>
    </values>
    <values>
        <field>Remediation__c</field>
        <value xsi:type="xsd:string">Increase event log retention to 30 days minimum in Setup &gt; Event Manager. For compliance-sensitive orgs, configure log forwarding to a SIEM to extend retention indefinitely beyond the Salesforce platform limit.</value>
    </values>
