<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <label>AGA-001 - Agentforce Action without conf</label>
    <protected>false</protected>
    <values>
        <field>CheckId__c</field>
        <value xsi:type="xsd:string">AGA-001</value>
    </values>
    <values>
        <field>CheckName__c</field>
        <value xsi:type="xsd:string">Agentforce Action without confirmation required</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Agentforce &amp; GenAI</value>
    </values>
    <values>
        <field>CategoryCode__c</field>
        <value xsi:type="xsd:string">AGA</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Critical</value>
    </values>
    <values>
        <field>FindingType__c</field>
        <value xsi:type="xsd:string">Automated</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">One or more Agentforce Action definitions (GenAiFunctionDefinition) have IsConfirmationRequired=false. The AI can take autonomous write actions without any human approval step.</value>
    </values>
    <values>
        <field>Impact__c</field>
        <value xsi:type="xsd:string">Agentforce Actions without confirmation can autonomously create, update, or delete records, send emails, or make API calls based on AI reasoning. A prompt injection attack or hallucination could trigger destructive operations without any human approval.</value>
    </values>
    <values>
        <field>Remediation__c</field>
        <value xsi:type="xsd:string">Enable IsConfirmationRequired=true on all Actions that perform write operations (DML, email, API calls). Reserve IsConfirmationRequired=false only for read-only informational actions.</value>
    </values>
    <values>
        <field>SalesforceDocUrl__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>