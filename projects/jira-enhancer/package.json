{
  "name": "jira-enhancer",
  "version": "1.0.0",
  "description": "Floating headers, quick copy, and smart search for Jira",
  "private": true,
  "scripts": {
    "lint": "eslint *.js lib/*.js --ext .js",
    "lint:fix": "eslint *.js lib/*.js --ext .js --fix",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "build": "node scripts/build.js",
    "dev": "node scripts/dev.js"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "archiver": "^6.0.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
