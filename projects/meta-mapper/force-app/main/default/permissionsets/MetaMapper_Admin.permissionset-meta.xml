<?xml version="1.0" encoding="UTF-8" ?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description
  >Grants full access to MetaMapper. Assign to admins and developers who need to run dependency scans. Provides Create/Read/Update (never Delete) on Metadata_Scan_Job__c and Metadata_Dependency__c, access to the MetaMapper LWC and Apex controller, and Named Credential principal access required for Tooling API callouts. Must be assigned before a user can access or operate MetaMapper. Does not grant access to broader org data beyond what the user's existing profile already permits.</description>
    <label>MetaMapper Admin</label>

    <!-- Object permissions -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Metadata_Scan_Job__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Metadata_Dependency__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Apex class access -->
    <classAccesses>
        <apexClass>DependencyJobController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>DependencyQueueable</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ScanResultFileQueueable</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ScanSummaryQueueable</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>DependencyCleanupBatch</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>MetadataDependencyDeletionBatch</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>DependencyCleanupScheduler</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ToolingApiHealthCheck</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>DependencyNotificationService</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- Named Credential principal access for Tooling API loopback -->
    <!-- Admin must also authorize the per-user Named Credential after assignment. -->
    <!-- See setup/SETUP.md for post-install authorization instructions. -->
    <externalDataSourceAccesses>
        <enabled>true</enabled>
        <externalDataSource>MetaMapper_Tooling_API</externalDataSource>
    </externalDataSourceAccesses>

    <!-- Custom Permission checked by ToolingApiHealthCheck.verify() before any callout. -->
    <!-- Without this, all users with this permission set get PERMISSION_SET_MISSING. -->
    <customPermissions>
        <enabled>true</enabled>
        <name>MetaMapper_Application_Access</name>
    </customPermissions>

    <!-- Metadata_Scan_Job__c field permissions -->
    <!-- Required for WITH USER_MODE queries, insert as user (createJob), and update as user (cancelJob, resumeJob). -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Scan_Job__c.Job_Type__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Scan_Job__c.Is_Active_Flows_Only__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Scan_Job__c.Batch_Size_Override__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Scan_Job__c.Components_Analyzed__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Metadata_Scan_Job__c.Component_Type_Counts__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Scan_Job__c.Scan_Diagnostic_Log__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Scan_Job__c.Last_Query_Row_Count__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Scan_Job__c.Last_Progress_Cycle__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Metadata_Scan_Job__c.Result_File_Id__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Metadata_Scan_Job__c.Scan_Summary_Text__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Scan_Job__c.Pause_Reason__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Metadata_Scan_Job__c.Has_Attempted_Result_Save__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field
    >Metadata_Scan_Job__c.Is_Platform_Events_Auto_Suppressed__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Scan_Job__c.Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Scan_Job__c.Status_Closed_At__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Scan_Job__c.Target_API_Name__c</field>
