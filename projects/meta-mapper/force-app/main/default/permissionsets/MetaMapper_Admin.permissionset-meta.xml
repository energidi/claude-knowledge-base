    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Scan_Job__c.Processing_Cycle_Count__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Metadata_Dependency__c field permissions -->
    <!-- Required for getNodeHierarchyForJob() WITH USER_MODE and insert as user rootNode in createJob(). -->
    <!-- Ancestor_Id_Index__c and Unique_Component_Key__c are engine-internal and excluded from -->
    <!-- the USER_MODE SELECT projection. Unique_Component_Key__c needs editable=true for the   -->
    <!-- root node insert in createJob(); readable is intentionally false (not projected to the LWC).   -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Dependency__c.Ancestor_Path__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Metadata_Dependency__c.Dependency_Context__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Dependency__c.Dependency_Depth__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
