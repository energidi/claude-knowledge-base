    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Dependency__c.Is_Dynamic_Reference__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Metadata_Dependency__c.Metadata_Id__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Dependency__c.Metadata_Name__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Metadata_Dependency__c.Metadata_Type__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Metadata_Dependency__c.Parent_Dependency__c</field>
